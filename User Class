#include <iostream>
#include <string>
#include <vector>

class User {
private:
	std::string username;
	std::string password;
	std::vector<std::string> my_Listings;

public:
	// Constructor
	User(const std::string& username, const std::string& password)
		: username(username), password(password) {}

	// Getters
	std::string getUsername() const { return username; }

	// Login Check
	bool login(std::string u, std::string p) const {
		return (u == username && p == password);
	}

	// Add a listing to the user's listings
	void addListing(const std::string& listing) {
		my_Listings.push_back(listing);
	}

	// Display user's listings
	void displayMyListings() const {
		std::cout << "\nListings for user: " << getUsername() << std::endl;
		for (const auto& listing : my_Listings) {
			std::cout << "- " << listing << "\n";
		}
	}
};
