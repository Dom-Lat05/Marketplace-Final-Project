#include <iostream>
#include <limits>
#include <string>
#include <vector>
#include "marketplaceSystem.h"

void clearInput() {
    std::cin.clear();
    std::cin.ignore(std::numeric_limits<std::streamsize>::max(), '\n');
}

void pauseScreen() {
    std::cout << "\nPress Enter to continue...";
    std::cin.get();
}

void displayAllListings(MarketplaceSystem& system) {
    std::vector<Listing> listings = system.getAllListings();

    if (listings.empty()) {
        std::cout << "\nNo listings available.\n";
        return;
    }

    std::cout << "\n===== ALL LISTINGS =====\n";
    for (size_t i = 0; i < listings.size(); ++i) {
        std::cout << "\nListing #" << i + 1 << "\n";
        listings[i].displayDetails();
        std::cout << "-------------------------\n";
    }
}

void searchListingsByName(MarketplaceSystem& system) {
    std::string searchName;
    std::cout << "\nEnter listing name to search: ";
    std::getline(std::cin, searchName);

    std::vector<Listing> listings = system.getAllListings();
    bool found = false;

    std::cout << "\n===== SEARCH RESULTS =====\n";
    for (const auto& listing : listings) {
        if (listing.getName() == searchName) {
            listing.displayDetails();
            std::cout << "-------------------------\n";
            found = true;
        }
    }

    if (!found) {
        std::cout << "No listings found with that name.\n";
    }
}

void filterListingsByCategory(MarketplaceSystem& system) {
    std::string category;
    std::cout << "\nEnter category to filter by: ";
    std::getline(std::cin, category);

    std::vector<Listing> listings = system.getAllListings();
    bool found = false;

    std::cout << "\n===== FILTER RESULTS =====\n";
    for (const auto& listing : listings) {
        if (listing.getCategory() == category) {
            listing.displayDetails();
            std::cout << "-------------------------\n";
            found = true;
        }
    }

    if (!found) {
        std::cout << "No listings found in that category.\n";
    }
}

void createListing(MarketplaceSystem& system) {
    std::string name;
    std::string description;
    std::string category;
    std::string condition;
    std::string location;
    double price;

    std::cout << "\n===== CREATE LISTING =====\n";

    std::cout << "Enter item name: ";
    std::getline(std::cin, name);

    std::cout << "Enter description: ";
    std::getline(std::cin, description);

    std::cout << "Enter category: ";
    std::getline(std::cin, category);

    std::cout << "Enter condition: ";
    std::getline(std::cin, condition);

    std::cout << "Enter location: ";
    std::getline(std::cin, location);

    std::cout << "Enter price: ";
    while (!(std::cin >> price) || price < 0) {
        std::cout << "Invalid price. Enter a valid number: ";
        clearInput();
    }
    clearInput();

    if (system.addListing(name, description, category, condition, location, price)) {
        std::cout << "Listing created successfully.\n";
    }
    else {
        std::cout << "Failed to create listing.\n";
    }
}

void viewMyListings(MarketplaceSystem& system) {
    if (!system.isLoggedIn()) {
        std::cout << "\nYou must be logged in first.\n";
        return;
    }

    std::vector<Listing>& myListings = system.getMyListings();

    if (myListings.empty()) {
        std::cout << "\nYou have no listings.\n";
        return;
    }

    std::cout << "\n===== MY LISTINGS =====\n";
    for (size_t i = 0; i < myListings.size(); ++i) {
        std::cout << "\nMy Listing #" << i + 1 << "\n";
        myListings[i].displayDetails();
        std::cout << "-------------------------\n";
    }
}

void markListingSold(MarketplaceSystem& system) {
    if (!system.isLoggedIn()) {
        std::cout << "\nYou must be logged in first.\n";
        return;
    }

    std::string listingName;
    std::cout << "\nEnter the name of the listing to mark as sold: ";
    std::getline(std::cin, listingName);

    if (system.markListingAsSold(listingName)) {
        std::cout << "Listing marked as sold successfully.\n";
    }
    else {
        std::cout << "Could not mark listing as sold.\n";
    }
}

void loggedInMenu(MarketplaceSystem& system) {
    int choice = 0;

    while (system.isLoggedIn()) {
        std::cout << "\n===== USER MENU =====\n";
        std::cout << "Logged in as: " << system.getCurrentUsername() << "\n";
        std::cout << "1. Create Listing\n";
        std::cout << "2. View My Listings\n";
        std::cout << "3. View All Listings\n";
        std::cout << "4. Search Listings by Name\n";
        std::cout << "5. Filter Listings by Category\n";
        std::cout << "6. Mark Listing as Sold\n";
        std::cout << "7. Logout\n";
        std::cout << "Enter your choice: ";

        while (!(std::cin >> choice)) {
            std::cout << "Invalid choice. Enter a number: ";
            clearInput();
        }
        clearInput();

        switch (choice) {
        case 1:
            createListing(system);
            system.saveData();
            pauseScreen();
            break;
        case 2:
            viewMyListings(system);
            pauseScreen();
            break;
        case 3:
            displayAllListings(system);
            pauseScreen();
            break;
        case 4:
            searchListingsByName(system);
            pauseScreen();
            break;
        case 5:
            filterListingsByCategory(system);
            pauseScreen();
            break;
        case 6:
            markListingSold(system);
            system.saveData();
            pauseScreen();
            break;
        case 7:
            system.logout();
            system.saveData();
            std::cout << "Logged out successfully.\n";
            break;
        default:
            std::cout << "Invalid option.\n";
            pauseScreen();
        }
    }
}

int main() {
    MarketplaceSystem marketplaceSystem;
    marketplaceSystem.loadData();

    int choice = 0;
    bool running = true;

    while (running) {
        std::cout << "\n===== ONLINE MARKETPLACE =====\n";
        std::cout << "1. Create Account\n";
        std::cout << "2. Login\n";
        std::cout << "3. View All Listings\n";
        std::cout << "4. Search Listings by Name\n";
        std::cout << "5. Filter Listings by Category\n";
        std::cout << "6. Exit\n";
        std::cout << "Enter your choice: ";

        while (!(std::cin >> choice)) {
            std::cout << "Invalid choice. Enter a number: ";
            clearInput();
        }
        clearInput();

        switch (choice) {
        case 1: {
            std::string username;
            std::string password;

            std::cout << "\n===== CREATE ACCOUNT =====\n";
            std::cout << "Enter username: ";
            std::getline(std::cin, username);

            std::cout << "Enter password: ";
            std::getline(std::cin, password);

            if (marketplaceSystem.createUser(username, password)) {
                marketplaceSystem.saveData();
                std::cout << "Account created successfully.\n";
            }
            else {
                std::cout << "Could not create account.\n";
            }

            pauseScreen();
            break;
        }
        case 2: {
            std::string username;
            std::string password;

            std::cout << "\n===== LOGIN =====\n";
            std::cout << "Enter username: ";
            std::getline(std::cin, username);

            std::cout << "Enter password: ";
            std::getline(std::cin, password);

            if (marketplaceSystem.login(username, password)) {
                loggedInMenu(marketplaceSystem);
            }
            else {
                std::cout << "Login failed.\n";
                pauseScreen();
            }
            break;
        }
        case 3:
            displayAllListings(marketplaceSystem);
            pauseScreen();
            break;
        case 4:
            searchListingsByName(marketplaceSystem);
            pauseScreen();
            break;
        case 5:
            filterListingsByCategory(marketplaceSystem);
            pauseScreen();
            break;
        case 6:
            marketplaceSystem.saveData();
            std::cout << "Data saved. Goodbye.\n";
            running = false;
            break;
        default:
            std::cout << "Invalid option.\n";
            pauseScreen();
        }
    }

    return 0;
}
